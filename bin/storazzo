#!/usr/bin/env ruby
# frozen_string_literal: true

require 'bundler/setup'
$LOAD_PATH.unshift(File.expand_path('../lib', __dir__))
require 'storazzo'
require 'thor'

if RUBY_VERSION.split('.')[0].to_i < 3
  puts 'Refusing to launch a script form Ruby < 3.'
  exit 2020
end

module Storazzo
  class CLI < Thor
    include ::Storazzo::Colors
    include ::Storazzo::Common

    class_option :verbose, type: :boolean, default: false, desc: 'Output more information'
    class_option :debug, type: :boolean, default: false, desc: 'Enable debug mode'

    desc "init [PATH]", "Initialize Storazzo configuration (global or local). Defaults to current directory."
    def init(path = ".")
      setup_env
      # 1. Global config
      global_config = File.expand_path('~/.storazzo.yaml')
      unless File.exist?(global_config)
        if yes?("No global config found. Create one at #{global_config}?")
          project_id = ask("Google Cloud Project ID?", default: "your-project-id")
          bucket_path = ask("Default GCS Bucket Path (gs://bucket-name/path/)?", default: "gs://my-bucket/storazzo/")
          
          config_content = File.read(Storazzo::RicDiskConfig.gem_default_config_path)
          config_content.gsub!("YOUR-PROJECT-ID", project_id)
          config_content.gsub!("gs://my-local-backup/storazzo/backups/", bucket_path)
          
          File.write(global_config, config_content)
          puts "Global config created at #{global_config}!"
        end
      end

      # 2. Local config (for the folder)
      dir = File.expand_path(path)
      local_config = File.join(dir, "storazzo.yaml")
      
      if File.exist?(local_config)
        puts "Local config already exists at #{local_config}"
      else
        if yes?("Initialize folder #{dir} with a storazzo.yaml?")
          name = ask("Disk/Folder Name?", default: File.basename(dir))
          tags = ask("Tags (comma separated)?", default: "storazzo, backup")
          
          require 'securerandom'
          content = {
            "kind" => "RicDisk",
            "apiVersion" => "v2.1",
            "name" => name,
            "disk_uuid" => SecureRandom.uuid,
            "tags" => tags.split(",").map(&:strip),
            "created_at" => Time.now.to_s,
            "computation_hostname" => Socket.gethostname
          }
          File.write(local_config, content.to_yaml)
          puts "Local config created at #{local_config}"
        end
      end
    end
    map "new-folder" => :init

    desc "scan PATH", "Scan a removable disk or local folder and upload its metadata to GCS"
    method_option :force, type: :boolean, default: false, desc: "Force re-scanning even if stats file exists"
    method_option :stats_file, type: :string, desc: "Override default stats filename"
    def scan(path)
      setup_env
      puts "Scanning path: #{path}"
      
      is_gcs = path.start_with?("gs://")
      dir = is_gcs ? path : File.expand_path(path)
      
      unless is_gcs || File.directory?(dir)
        puts "Error: #{dir} is not a valid directory."
        exit 1
      end

      config = Storazzo::RicDiskConfig.instance
      config.load

      rd = Storazzo::RicDisk.new(Storazzo::Media::AbstractRicDisk.DirFactory(dir))
      
      unless is_gcs || rd.ok_dir?
        puts "missing .yaml (storazzo.yaml) for folder #{dir}. \nRun \"storazzo new-folder #{path}\" to initialize it with a small Wizard which asks you the right Qs."
        exit 2
      end

      rd.write_config_yaml_to_disk(dir) unless is_gcs
      
      scan_opts = { upload_to_gcs: true }
      scan_opts[:force] = options[:force] if options[:force]
      scan_opts[:stats_file] = options[:stats_file] if options[:stats_file]
      
      rd.compute_stats_files(scan_opts)

      puts "Scan completed for #{dir}."
    end

    desc "search QUERY", "Search for a keyword across all indexed disks via SQLite DB"
    method_option :skip_sync, type: :boolean, default: false, desc: 'Skip syncing from GCS'
    def search(query)
      setup_env
      require 'storazzo/search_engine'
      
      puts "Searching for: #{query}"
      engine = Storazzo::SearchEngine.new
      engine.sync_from_gcs unless options[:skip_sync]
      results = engine.query(query)
      
      if results.empty?
        puts "No results found for '#{query}'."
      else
        puts "Found #{results.size} matches:"
        results.each do |r|
          puts "- [#{r['disk_name']}] #{r['path']} (size: #{r['size']})"
        end
      end
    end

    desc "backup SRC DEST", "Backup a local folder to GCS and update index"
    def backup(src, dest)
      setup_env
      puts "Backing up #{src} to #{dest}"
      
      src_dir = File.expand_path(src)
      unless File.directory?(src_dir)
        puts "Error: #{src_dir} is not a valid directory."
        exit 1
      end

      # 1. Run gsutil rsync
      cmd = "gsutil -m rsync -r '#{src_dir}' '#{dest}'"
      puts "Running: #{cmd}"
      system(cmd)
      unless $?.success?
        puts "Failed to backup files to GCS."
        exit 1
      end

      # 2. Compute stats on the destination bucket
      require 'storazzo/search_engine'
      # We could run `stats-with-md5` for GCS here to generate the index
      # and upload to metadata bucket
      puts "Indexing GCS bucket: #{dest}"
      cmd_stats = "stats-with-md5 --autowrite '#{dest}'"
      system(cmd_stats)

      puts "Backup and indexing completed."
    end

    desc "summarize PATH", "Generate an LLM-powered summary for a disk's catalog"
    method_option :force, type: :boolean, default: false, desc: 'Overwrite existing summary if it exists'
    def summarize(path)
      setup_env
      dir = File.expand_path(path)
      unless File.directory?(dir)
        puts "Error: #{dir} is not a valid directory."
        exit 1
      end

      summary_file = File.join(dir, "storazzo.yaml")
      if File.exist?(summary_file) && !options[:force]
        puts "Warning: A summary file already exists at #{summary_file}."
        puts "Use --force to rewrite it."
        exit 0
      end

      puts "Generating summary for #{dir}..."
      rd = Storazzo::RicDisk.new(Storazzo::Media::AbstractRicDisk.DirFactory(dir))
      rd.generate_summary_yaml
      puts "Summary generated successfully."
    end

    desc "show", "Show options and local folders"
    def show
      setup_env
      puts "1. GCS Buckets"
      Storazzo::Media::GcsBucket.list_all_with_type.each do |item|
        render_item(item)
      end

      puts "\n2. Local Mounts & Folders"
      Storazzo::Media::AbstractRicDisk.super_duper_list_all_with_type.each do |item|
        next if item[0] == :config_gcs_bucket || item[0] == :gsutil_ls_gcs_bucket
        render_item(item)
      end
    end

    private

    def render_item(item)
      type, path = item
      case type
      when :config_gcs_bucket, :gsutil_ls_gcs_bucket
        puts "🪣  #{azure(path)}"
      when :mount_point_todo_less_generic
        puts "💽  #{yellow(path)}"
      when :local_folder
        puts "📁  #{green(path)}"
      else
        puts "⚪  #{path} (type: #{type})"
      end
    end

    def setup_env
      $DEBUG = options[:debug]
      $opts = { verbose: options[:verbose], debug: options[:debug] }
      
      begin
        config = Storazzo::RicDiskConfig.instance
        config.load
        bucket_path = config.get_bucket_paths.first
        if bucket_path
          # Remove gs:// and trailing slash
          $gcs_bucket = bucket_path.gsub(%r{^gs://}, "").gsub(%r{/$}, "")
        end
      rescue => e
        # Silently fail if config can't be loaded yet (e.g. during init)
        deb "setup_env: Could not load config for $gcs_bucket: #{e.message}"
      end
    end
  end
end

Storazzo::CLI.start(ARGV)
